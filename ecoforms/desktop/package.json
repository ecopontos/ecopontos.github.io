{
  "name": "ecosuite-desktop",
  "version": "0.1.8",
  "private": true,
  "scripts": {
    "dev": "npm run dev:clean && next dev -p 3001",
    "dev:clean": "node -e \"const fs=require('fs'); if(fs.existsSync('.next')) fs.rmSync('.next',{recursive:true,force:true});\" ",
    "clean:desktop": "node -e \"const fs=require('fs'); const rm=(p)=>{ if(fs.existsSync(p)){ fs.rmSync(p,{recursive:true,force:true}); }}; rm('.next'); rm('src-tauri/target');\"",
    "build": "next build",
    "build:tauri": "npm run build && npx tauri build",
    "tauri": "cargo tauri",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start:tauri": "cargo tauri dev",
    "audit:db": "node scripts/audit-db-consistency.js"
  },
