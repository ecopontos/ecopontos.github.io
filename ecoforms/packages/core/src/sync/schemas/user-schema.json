{
  "schema_version": 1,
  "domain": "user",
  "description": "Campos de usuarios — projecao de sync desktop ↔ mobile via shared/users.json",
  "required": ["id", "username", "nome", "perfil"],
  "fields": {
    "id": { "type": "string" },
    "username": { "type": "string" },
    "nome": { "type": "string" },
    "perfil": { "type": "string", "enum": ["admin", "gerente", "coordenador", "encarregado", "operador"] },
    "formularios_permitidos": { "type": "array", "items": { "type": "string" } },
    "ativo": { "type": "boolean" },
    "setor": { "type": "string", "nullable": true },
    "setores": { "type": "array", "items": { "type": "string" }, "nullable": true },
    "password_hash": { "type": "string" },
    "created_at": { "type": "string", "nullable": true },
    "updated_at": { "type": "string", "nullable": true }
  }
}
