  "required": ["id", "slug", "name", "entity_type"],
  "fields": {
    "id": { "type": "string" },
    "slug": { "type": "string" },
    "name": { "type": "string" },
    "entity_type": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "published", "archived"] },
    "version": { "type": "number" },
    "config": { "type": "object" },
    "publicado_em": { "type": "string", "nullable": true }
  }
}
