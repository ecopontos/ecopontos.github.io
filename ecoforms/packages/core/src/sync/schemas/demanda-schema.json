{
  "schema_version": 1,
  "domain": "demanda",
  "description": "Campos de Demanda.toSyncJSON() — projecao de sync desktop ↔ mobile",
  "required": ["id", "solicitante_id", "destinatario_id", "status"],
  "fields": {
    "id": { "type": "string" },
    "origem_tipo": { "type": "string" },
    "origem_id": { "type": "string", "nullable": true },
    "solicitante_id": { "type": "string" },
    "destinatario_id": { "type": "string" },
    "tipo_acao": { "type": "string" },
    "descricao": { "type": "string", "nullable": true },
    "status": { "type": "string", "enum": ["aberta", "aceita", "concluida"] },
    "politica_conclusao": { "type": "string", "enum": ["declarado", "verificado"] },
    "auto_aceite": { "type": "number", "enum": [0, 1] },
    "aceito_por": { "type": "string", "nullable": true },
    "aceito_em": { "type": "string", "nullable": true },
    "encerrado_por": { "type": "string", "nullable": true },
    "encerrado_em": { "type": "string", "nullable": true },
    "criada_em": { "type": "string", "nullable": true },
    "arquivada_em": { "type": "string", "nullable": true },
    "arquivo_path": { "type": "string", "nullable": true },
    "archive_status": { "type": "string", "nullable": true },
    "created_at": { "type": "string", "nullable": true }
  }
}
