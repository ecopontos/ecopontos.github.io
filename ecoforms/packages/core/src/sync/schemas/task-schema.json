{
  "schema_version": 1,
  "domain": "task",
  "description": "Campos de Task.toSyncJSON() — projecao de sync desktop ↔ mobile",
  "required": ["id", "titulo", "status", "prioridade", "criado_por"],
  "fields": {
    "id": { "type": "string" },
    "projeto_id": { "type": "string", "nullable": true },
    "titulo": { "type": "string" },
    "descricao": { "type": "string", "nullable": true },
    "status": { "type": "string", "enum": ["a_fazer", "em_progresso", "concluido", "cancelado"] },
    "prioridade": { "type": "string", "enum": ["baixa", "media", "alta"] },
    "atribuido_para": { "type": "string", "nullable": true },
    "criado_por": { "type": "string" },
    "prazo": { "type": "string", "nullable": true },
    "prazo_fim": { "type": "string", "nullable": true },
    "tipo_prazo": { "type": "string", "nullable": true, "enum": ["unico", "periodo", "recorrente"] },
    "recorrencia": { "type": "string", "nullable": true },
    "ordem": { "type": "number" },
    "arquivado": { "type": "number", "enum": [0, 1] },
    "form_registry_id": { "type": "string", "nullable": true },
    "tbl_suite_id": { "type": "string", "nullable": true },
    "demanda_id": { "type": "string", "nullable": true },
    "created_at": { "type": "string", "nullable": true },
    "updated_at": { "type": "string", "nullable": true }
  }
}
