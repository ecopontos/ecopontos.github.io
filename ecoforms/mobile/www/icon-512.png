<svg width="512" height="512" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#007bff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0056b3;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" rx="64" fill="url(#grad1)"/>
  
  <!-- Icon content - Presence/Check symbol -->
  <g transform="translate(128, 128)">
    <!-- Person icon -->
    <circle cx="128" cy="85" r="42" fill="white" opacity="0.9"/>
    <path d="M128 149 C85 149, 53 181, 53 224 L53 256 L203 256 L203 224 C203 181, 171 149, 128 149 Z" fill="white" opacity="0.9"/>
    
    <!-- Check mark -->
    <g transform="translate(160, 53)">
      <circle cx="42" cy="42" r="42" fill="#28a745"/>
      <path d="M21 42 L37 58 L64 27" stroke="white" stroke-width="8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    </g>
  </g>
  
  <!-- App name -->
  <text x="256" y="450" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="36" font-weight="bold">PRESENÇA</text>
  <text x="256" y="480" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="18" opacity="0.8">COOPERADOS</text>
</svg>