{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "allowJs": true,
        "checkJs": false,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "./types",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "ignoreDeprecations": "6.0",
        "moduleResolution": "node"
    },
    "include": [
        "js/**/*.js",
        "js/**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "js/vendor/**"
    ]
}