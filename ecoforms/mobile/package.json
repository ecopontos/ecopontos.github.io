{
  "name": "ecoforms",
  "version": "1.0.1",
  "type": "module",
  "description": "Sistema completo de formulários ecológicos",
  "main": "index.js",
  "scripts": {
    "tauri": "npm run tauri --prefix desktop --",
    "desktop": "npm run dev --prefix desktop",
    "build-css": "tailwindcss -i ./styles/input.css -o ./styles/tailwind.css --watch",
    "build-css-prod": "tailwindcss -i ./styles/input.css -o ./styles/tailwind.css --minify",
    "concat-css": "node ./scripts/concat-css.js",
    "build-core": "node scripts/build-core.js",
    "build": "npm run build-core && npm run build-css-prod && npm run concat-css && npm run sync-field-css",
    "dev": "npm run build-css",
    "dev:server": "node dev-server.js",
    "sync-field-css": "node ./scripts/sync-field-css.js",
    "serve": "http-server www -p 5502 -c-1 --cors",
    "start": "node start-all.cjs",
    "debug-mobile": "npm run build-css-prod && npx cap sync && npx cap open android",
    "build-debug": "npm run build-css-prod && npx cap sync && cd android && gradlew assembleDebug",
    "install-debug": "npm run build-debug && adb install android/app/build/outputs/apk/debug/app-debug.apk",
    "cap-sync": "npm run build && npx cap sync",
    "rebuild-install": "npm run cap-sync && cd android && .\\gradlew assembleDebug && adb install -r app\\build\\outputs\\apk\\debug\\app-debug.apk",
    "test-format": "node test-data-format.js",
    "test:fields": "node www/js/fields/test-computeDefaultValue.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:performance": "vitest run tests/performance.benchmark.test.js",
    "test:perf": "npm run test:performance",
    "benchmark": "npm run test:performance",
    "benchmark:100": "vitest run tests/performance.benchmark.test.js -t '100 campos'",
    "benchmark:500": "vitest run tests/performance.benchmark.test.js -t '500 campos'",
    "benchmark:1000": "vitest run tests/performance.benchmark.test.js -t '1000 campos'",
    "benchmark:compare": "vitest run tests/performance.benchmark.test.js -t 'Comparação'",
    "build-ecoponto": "npm run build && echo \"Versão Ecoponto construída\""
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "context-mode": "^1.0.109",
    "esbuild": "^0.25.0",
    "happy-dom": "^20.0.2",
    "http-server": "^14.1.1",
    "playwright": "^1.41.1",
    "postcss": "^8.5.6",
    "serve": "^14.2.5",
    "tailwindcss": "^3.4.17",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.0.2",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@ionic/pwa-elements": "^3.3.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@supabase/supabase-js": "^2.58.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "ecoforms-core": "*",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "jsdom": "^27.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  }
}
